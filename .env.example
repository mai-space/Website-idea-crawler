# Database
DATABASE_URL=postgresql://sitebrief:sitebrief@localhost:5432/sitebrief

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AI — idea generation
# V2: set ANTHROPIC_API_KEY to use Claude (preferred). Falls back to OpenAI GPT-4o if only OPENAI_API_KEY is set.
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI is still used for text-embedding-3-small (Claude has no embeddings API)
OPENAI_API_KEY=sk-...
OPENAI_TPM_BUDGET=100000

# Notifications (optional) — POST JSON when a new idea is created
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# NOTIFY_WEBHOOK_URL=https://example.com/your-ingest-endpoint

# Crawler
CRAWLER_DEFAULT_DEPTH=3
CRAWLER_MAX_PAGES=500
CRAWLER_RATE_LIMIT_RPS=2
CRAWLER_TIMEOUT_MS=10000

# Auth
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=7d

# App
PORT=3001
FRONTEND_URL=http://localhost:5173
